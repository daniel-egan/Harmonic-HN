<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingStart="16dp"
    android:paddingTop="12dp"
    android:paddingEnd="16dp"
    android:paddingBottom="12dp">

    <TextView
        android:id="@android:id/title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="@font/product_sans"
        android:textColor="?attr/storyColorNormal"
        android:textSize="16sp" />

    <com.google.android.material.button.MaterialButtonToggleGroup
        android:id="@+id/story_preview_image_mode_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        app:selectionRequired="true"
        app:singleSelection="true">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/story_preview_image_mode_off"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checkable="true"
            android:fontFamily="@font/product_sans_bold"
            android:text="Off"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/story_preview_image_mode_small"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checkable="true"
            android:fontFamily="@font/product_sans_bold"
            android:text="Small"
            android:textAllCaps="false" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/story_preview_image_mode_large"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:checkable="true"
            android:fontFamily="@font/product_sans_bold"
            android:text="Large"
            android:textAllCaps="false" />

    </com.google.android.material.button.MaterialButtonToggleGroup>

</LinearLayout>
